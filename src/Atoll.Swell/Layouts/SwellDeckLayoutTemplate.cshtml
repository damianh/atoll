@inherits Atoll.Components.AtollLayoutSlice<Atoll.Swell.Layouts.SwellDeckLayoutModel>
@using Atoll.Swell.Layouts
@using Atoll.Swell.Styles
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@Model.Config.Title</title>
<meta name="generator" content="Atoll.Swell" />
<style>@{ WriteLiteral(SwellTheme.AllCss); }</style>
</head>
<body>
<a href="#swell-deck" class="swell-skip-link">Skip to slide content</a>
<div id="swell-deck"
     class="swell-deck"
     style="aspect-ratio:@Model.AspectRatioCss"
     data-total-slides="@Model.Slides.Count"
     data-default-transition="@Model.Config.Transition.ToString().ToLowerInvariant()"
     role="region"
     aria-label="@(string.IsNullOrEmpty(Model.Config.Title) ? "Slide deck" : Model.Config.Title)">
    @{ await RenderBodyAsync(); }
</div>
<nav id="swell-navbar" class="swell-navbar" aria-label="Slide navigation">
    <button type="button" data-swell-action="prev" title="Previous slide (←)" aria-label="Previous slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <span class="swell-navbar-counter" data-swell-counter>1 / @Model.Slides.Count</span>
    <button type="button" data-swell-action="next" title="Next slide (→)" aria-label="Next slide">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <span class="swell-navbar-sep"></span>
    <button type="button" data-swell-action="overview" title="Overview (o)" aria-label="Toggle overview">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
    </button>
    <button type="button" data-swell-action="fullscreen" title="Fullscreen (f)" aria-label="Toggle fullscreen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
    </button>
    <button type="button" data-swell-action="presenter" title="Presenter mode (p)" aria-label="Open presenter mode">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </button>
    <button type="button" data-swell-action="drawing" title="Drawing (d)" aria-label="Toggle drawing">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>
    </button>
    <button type="button" data-swell-action="download" title="Download PDF (print)" aria-label="Download as PDF">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    </button>
</nav>
<div id="swell-presenter-notes" hidden>
    @foreach (var slide in Model.Slides)
    {
        <div data-slide-index="@slide.Index">@{ WriteLiteral(slide.Notes); }</div>
    }
</div>
<script src="/scripts/atoll-swell-nav.js" defer></script>
<script src="/scripts/atoll-swell-drawing.js" defer></script>
</body>
</html>

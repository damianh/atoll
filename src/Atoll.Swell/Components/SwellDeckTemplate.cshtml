@inherits Atoll.Components.AtollSlice<Atoll.Swell.Components.SwellDeckModel>
@using Atoll.Swell.Components
<div class="swell-embed" style="position:relative;width:100%;aspect-ratio:@Model.AspectRatioCss;overflow:hidden;background:#1a1a2e;border:1px solid #d1d5db;border-radius:8px;">
    <iframe src="@Model.Src"
            title="@Model.Title"
            style="position:absolute;inset:0;width:100%;height:100%;border:none;"
            allow="fullscreen"
            loading="lazy">
    </iframe>
    <a href="@Model.Src"
       target="_blank"
       rel="noopener noreferrer"
       title="Open in fullscreen"
       aria-label="Open slide deck in fullscreen"
       style="position:absolute;top:0.5rem;right:0.5rem;background:rgba(0,0,0,0.5);color:#fff;border-radius:4px;padding:0.25rem 0.5rem;font-size:0.75rem;text-decoration:none;line-height:1;display:flex;align-items:center;gap:0.25rem;">
        ⛶ Fullscreen
    </a>
</div>

@inherits Atoll.Components.AtollLayoutSlice<Atoll.Lagoon.Layouts.SplashLayoutModel>
@using Atoll.Lagoon.Islands
@using Atoll.Lagoon.Layouts
<!DOCTYPE html>
<html lang="en">
@{ await RenderComponentAsync<DocsBaseHead>(new Dictionary<string, object?>
{
    ["Config"] = Model.Config,
    ["PageTitle"] = Model.PageTitle,
    ["PageDescription"] = Model.PageDescription,
    ["CurrentPath"] = Model.CurrentPath,
    ["SiteUrl"] = Model.SiteUrl,
}); }
<body>
    <header class="docs-header">
        <div class="docs-header-inner">
            <a href="/" class="docs-brand">
                <img src="@Model.LogoSrc" alt="@Model.Config.LogoAlt" class="docs-logo" />
                @Model.Config.Title
            </a>
            <div class="docs-header-actions">
                @{
                    var searchIndexUrl = string.IsNullOrEmpty(Model.Config.BasePath)
                        ? "/search-index.json"
                        : Model.Config.BasePath.TrimEnd('/') + "/search-index.json";
                    await RenderComponentAsync<SearchDialog>(new Dictionary<string, object?>
                    {
                        ["Translations"] = Model.Config.Translations,
                        ["IndexUrl"] = searchIndexUrl,
                        ["BasePath"] = Model.Config.BasePath,
                    });
                }
                @foreach (var social in Model.Config.Social)
                {
                    <a href="@social.Url" class="docs-social-link" rel="noopener noreferrer" target="_blank">@social.Label</a>
                }
                @{ await RenderComponentAsync<ThemeToggle>(new Dictionary<string, object?>
                {
                    ["Translations"] = Model.Config.Translations,
                }); }
            </div>
        </div>
    </header>
    @if (Model.Config.Banner is { Enabled: true } banner && !string.IsNullOrEmpty(banner.Content))
    {
        var bannerVariantClass = banner.Variant switch
        {
            Atoll.Lagoon.Configuration.BannerVariant.Info    => "docs-banner-info",
            Atoll.Lagoon.Configuration.BannerVariant.Warning => "docs-banner-warning",
            Atoll.Lagoon.Configuration.BannerVariant.Success => "docs-banner-success",
            Atoll.Lagoon.Configuration.BannerVariant.Danger  => "docs-banner-danger",
            _ => "docs-banner-info",
        };
        if (banner.Dismissible)
        {
            WriteLiteral($"<div class=\"docs-banner {bannerVariantClass}\" role=\"status\" id=\"docs-banner\" data-dismiss-key=\"{Atoll.Rendering.HtmlEncoder.Encode(banner.DismissKey)}\">");
        }
        else
        {
            WriteLiteral($"<div class=\"docs-banner {bannerVariantClass}\" role=\"status\" id=\"docs-banner\">");
        }
        <span class="docs-banner-content">@{ WriteLiteral(banner.Content); }</span>
        @if (banner.LinkHref is not null && banner.LinkText is not null)
        {
            <a href="@banner.LinkHref">@banner.LinkText</a>
        }
        @if (banner.Dismissible)
        {
            <button type="button" class="docs-banner-dismiss" aria-label="@Model.Config.Translations.BannerDismissLabel">&times;</button>
        }
        WriteLiteral("</div>");
        @if (banner.Dismissible)
        {
            <script>
            (function(){
                var b=document.getElementById('docs-banner');
                if(!b)return;
                var k=b.getAttribute('data-dismiss-key');
                if(k&&localStorage.getItem(k)==='1'){b.hidden=true;return;}
                var btn=b.querySelector('.docs-banner-dismiss');
                if(btn){btn.addEventListener('click',function(){b.hidden=true;if(k)localStorage.setItem(k,'1');});}
            })();
            </script>
        }
    }
    <main class="splash-main" id="main-content">
        <article class="splash-content">
            @{ await RenderBodyAsync(); }
        </article>
    </main>
    <footer class="docs-footer">
        <p>Built with <a href="https://github.com/damianh/atoll">Atoll</a> &mdash; a .NET-native framework inspired by Astro.</p>
    </footer>
    @if (Model.EnableMermaid)
    {
        <script src="/scripts/atoll-docs-mermaid-init.js" type="module"></script>
    }
</body>
</html>

@inherits Atoll.Components.AtollSlice<Atoll.Lagoon.Layouts.DocsBaseHeadModel>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>@if (!string.IsNullOrEmpty(Model.PageTitle)) { @Model.PageTitle<text> | </text>}@Model.Config.Title</title>
@if (!string.IsNullOrEmpty(Model.Description))
{
    <meta name="description" content="@Model.Description" />
}
<link rel="icon" type="image/png" href="@Model.FaviconHref" />
<script>
(function(){var s=localStorage.getItem('atoll-theme');if(s==='dark'||s==='light'){document.documentElement.setAttribute('data-theme',s);}else if(window.matchMedia('(prefers-color-scheme: dark)').matches){document.documentElement.setAttribute('data-theme','dark');}})();
</script>
@foreach (var css in Model.Config.CustomCss)
{
    <link rel="stylesheet" href="@css" />
}
@if (Model.OgImageUrl is not null)
{
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@Model.OgTitle" />
    @if (!string.IsNullOrEmpty(Model.OgDescription))
    {
        <meta property="og:description" content="@Model.OgDescription" />
    }
    @if (Model.OgUrl is not null)
    {
        <meta property="og:url" content="@Model.OgUrl" />
    }
    <meta property="og:image" content="@Model.OgImageUrl" />
    <meta property="og:site_name" content="@Model.SiteName" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@Model.OgTitle" />
    @if (!string.IsNullOrEmpty(Model.OgDescription))
    {
        <meta name="twitter:description" content="@Model.OgDescription" />
    }
    <meta name="twitter:image" content="@Model.OgImageUrl" />
}
@if (!string.IsNullOrEmpty(Model.PageHeadContent))
{
    WriteLiteral(Model.PageHeadContent);
}
</head>
